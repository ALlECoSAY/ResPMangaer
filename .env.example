# Telegram user API / MTProto
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_USER_SESSION_PATH=/app/config/telegram_user.session
TELEGRAM_USER_PHONE=
TELEGRAM_USER_2FA_PASSWORD=
TELEGRAM_LOGIN_CODE=
ALLOW_UNSAFE_ALL_CHATS=false

# YAML configs
ACCESS_CONTROL_ENABLED=true
WHITELIST_YAML_PATH=/app/config/whitelist.yaml
ADMINS_YAML_PATH=/app/config/admins.yaml
CONTEXT_LIMITS_YAML_PATH=/app/config/context_limits.yaml
REACTIONS_YAML_PATH=/app/config/reactions.yaml
ACTIVITY_YAML_PATH=/app/config/activity.yaml
STATS_YAML_PATH=/app/config/stats.yaml
PROMPTS_YAML_PATH=/app/config/prompts.yaml
IDENTITY_YAML_PATH=/app/config/identity.yaml

# OpenRouter
OPENROUTER_API_KEY=replace_me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=Telegram AI Thread Bot

# Image generation (avatar; disabled by default unless identity.yaml enables avatar.enabled)
IMAGE_GENERATION_API_KEY=
IMAGE_GENERATION_BASE_URL=https://api.openai.com/v1
IMAGE_GENERATION_MODEL=gpt-image-1

# Database
POSTGRES_DB=telegram_ai_bot
POSTGRES_USER=telegram_ai_bot
POSTGRES_PASSWORD=telegram_ai_bot_password
DATABASE_URL=postgresql+asyncpg://telegram_ai_bot:telegram_ai_bot_password@postgres:5432/telegram_ai_bot

# Safety / privacy
STORE_BOT_MESSAGES=true
STORE_COMMAND_MESSAGES=true
REDACT_TELEGRAM_USER_IDS=false

# Observability
LOG_LEVEL=INFO
LOG_PROMPTS=false
